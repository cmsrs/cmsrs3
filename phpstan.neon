includes:
    - vendor/larastan/larastan/extension.neon

parameters:

    paths:
        - app/
        - config/
#        - routes/
        - database/

    excludePaths:
        - app/Install.php

    # Level 9 is the highest level
    level: 7

    ignoreErrors:
        - identifier: method.childReturnType
          path: app/Models/Cmsrs


